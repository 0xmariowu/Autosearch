#!/usr/bin/env bash
unset GIT_DIR GIT_WORK_TREE GIT_INDEX_FILE

branch=$(git rev-parse --abbrev-ref HEAD)

if [ "$branch" = "main" ]; then
  exit 0
fi

# Rebase on main, then re-exec to pick up any hook changes from rebased commits
if [ "${_HUSKY_POST_REBASE:-}" != "1" ]; then
  git fetch origin main --quiet
  if ! git rebase origin/main --quiet; then
    echo "Rebase on main failed — resolve conflicts first."
    git rebase --abort
    exit 1
  fi
  echo "Rebased on origin/main"
  export _HUSKY_POST_REBASE=1
  exec bash "$(git rev-parse --show-toplevel)/.husky/pre-push" "$@"
fi

# Use uv-managed Python 3.11+ (codebase uses X | Y union syntax requiring 3.10+)
PYTHON=$(command -v python3.11 || command -v python3.12 || echo "")
if [ -z "$PYTHON" ]; then
  for p in "$HOME"/.local/share/uv/python/cpython-3.1*/bin/python3; do
    [ -x "$p" ] && PYTHON="$p" && break
  done
fi
if [ -z "$PYTHON" ]; then
  echo "warning: Python 3.10+ not found, skipping tests"
  exit 0
fi

"$PYTHON" -m unittest discover -s tests -q
